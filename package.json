{
  "name": "tavern",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node --experimental-sqlite --import tsx src/index.ts",
    "dev": "node --experimental-sqlite --watch --import tsx src/index.ts",
    "test": "node --experimental-sqlite ./node_modules/vitest/vitest.mjs run",

    "typecheck": "tsc --noEmit",
    "generate-catalog": "node --import tsx scripts/generate-catalog.ts"
  },

  "dependencies": {
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "multer": "^1.4.5-lts.1",
    "png-chunks-extract": "^1.0.0",

    "png-chunk-text": "^1.0.0",
    "gpt-tokenizer": "^2.8.0",
    "nanoid": "^5.0.9",
    "sanitize-filename": "^1.6.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/multer": "^1.4.12",
    "@types/node": "^24.0.0",



    "@types/png-chunks-extract": "^1.0.2",
    "@types/png-chunk-text": "^1.0.3",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8",
    "typescript": "^5.7.0"
  }
}
